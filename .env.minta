# Masold at ".env" neven, es töltsd ki a Circle hitelesito adataiddal.
# Copy this file as ".env" and fill in your Circle credentials.
#
# API key: https://console.circle.com (TEST environment, Standard Key)
# Entity secret: https://developers.circle.com/wallets/dev-controlled/register-entity-secret

CIRCLE_API_KEY=YOUR_CIRCLE_API_KEY
CIRCLE_ENTITY_SECRET=YOUR_ENTITY_SECRET
